              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Remove a user from the org."
        },
        {
          "info": {
            "name": "List Users",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "http://localhost:8099/users"
          },
          "docs": "List users in the current org."
        }
      ]
    },
