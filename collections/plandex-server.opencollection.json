        {
          "info": {
            "name": "Delete Invite",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "http://localhost:8099/invites/:inviteId",
            "params": [
              {
                "name": "inviteId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Revoke an outstanding invite."
        }
      ]
    },
    {
      "info": {
        "name": "Projects",
        "type": "folder"
